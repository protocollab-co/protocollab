{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "`protocollab` Extended Specification",
  "description": "Strict schema for `protocollab` protocol specifications",
  "type": "object",
  "required": ["meta"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z_][a-z0-9_]*$"
        },
        "title":       { "type": "string" },
        "version":     { "type": "string" },
        "description": { "type": "string" },
        "endian": {
          "type": "string",
          "enum": ["le", "be"]
        },
        "file-extension": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "encoding": { "type": "string" }
      },
      "additionalProperties": false
    },
    "seq": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id":       { "type": "string" },
          "type":     { "type": "string" },
          "size":     {},
          "if":       { "type": "string" },
          "repeat":   { "type": "string" },
          "repeat-expr": {},
          "doc":      { "type": "string" },
          "contents": {}
        },
        "additionalProperties": true
      }
    },
    "types":     { "type": "object" },
    "instances": { "type": "object" },
    "enums":     { "type": "object" },
    "imports": {
      "type": "array",
      "items": { "type": "string" }
    },
    "doc":     { "type": "string" },
    "doc-ref": { "type": "string" }
  },
  "additionalProperties": false
}
